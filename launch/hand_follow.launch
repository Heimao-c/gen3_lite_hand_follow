<launch>
  <arg name="robot_name" default="my_gen3"/>
  <arg name="dry_run" default="true"/>
  <arg name="enable_gesture_gripper" default="true"/>
  <arg name="gripper_dry_run" default="$(arg dry_run)"/>

  <arg name="base_frame" default="base_link"/>
  <arg name="tool_frame" default="end_effector_link"/>
  <arg name="camera_frame" default="camera_color_optical_frame"/>

  <arg name="color_topic" default="/camera/color/image_raw"/>
  <arg name="depth_topic" default="/camera/aligned_depth_to_color/image_raw"/>
  <arg name="camera_info_topic" default="/camera/color/camera_info"/>

  <!-- Optional static hand-eye TF. Usually publish this only if your calibrated TF
       is not already in the robot/camera TF tree.
       Args are parent->child: x y z qx qy qz qw parent child. -->
  <arg name="publish_handeye_tf" default="false"/>
  <arg name="handeye_parent_frame" default="$(arg tool_frame)"/>
  <arg name="handeye_child_frame" default="handeye_camera_color_optical_frame"/>
  <arg name="handeye_xyz_quat" default="0.08527739082893107 -0.07086621603976238 0.22382300230315322 -0.02818366984721186 -0.2042331373489352 0.43376901963502806 0.877119686227268"/>

  <rosparam command="load" file="$(find gen3_lite_hand_follow)/config/hand_follow.yaml"/>

  <node pkg="gen3_lite_hand_follow" type="hand_detector_node.py" name="hand_detector" output="screen">
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="camera_frame" value="$(arg camera_frame)"/>
    <param name="color_topic" value="$(arg color_topic)"/>
    <param name="depth_topic" value="$(arg depth_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
  </node>

  <node pkg="gen3_lite_hand_follow" type="hand_follow_controller_node.py" name="hand_follow_controller" output="screen">
    <param name="robot_name" value="$(arg robot_name)"/>
    <param name="dry_run" value="$(arg dry_run)"/>
    <param name="base_frame" value="$(arg base_frame)"/>
    <param name="tool_frame" value="$(arg tool_frame)"/>
    <param name="camera_frame" value="$(arg camera_frame)"/>
    <param name="cartesian_velocity_topic" value="/$(arg robot_name)/in/cartesian_velocity"/>
  </node>

  <node if="$(arg enable_gesture_gripper)"
        pkg="gen3_lite_hand_follow"
        type="gesture_gripper_node.py"
        name="gesture_gripper"
        output="screen">
    <param name="robot_name" value="$(arg robot_name)"/>
    <param name="service_name" value="/$(arg robot_name)/base/send_gripper_command"/>
    <param name="dry_run" value="$(arg gripper_dry_run)"/>
  </node>

  <node if="$(arg publish_handeye_tf)"
        pkg="tf2_ros"
        type="static_transform_publisher"
        name="handeye_static_tf"
        args="$(arg handeye_xyz_quat) $(arg handeye_parent_frame) $(arg handeye_child_frame)"/>
</launch>
